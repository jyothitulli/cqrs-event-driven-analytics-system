# Database Configuration
# Write database connection
DATABASE_URL=postgresql://user:password@write-db:5432/write_db

# Read database connection (for materialized views)
READ_DATABASE_URL=postgresql://user:password@read-db:5432/read_db

# Message Broker Configuration
# RabbitMQ connection URL
BROKER_URL=amqp://guest:guest@broker:5672/

# Service Ports
COMMAND_SERVICE_PORT=8080
QUERY_SERVICE_PORT=8081
CONSUMER_SERVICE_PORT=8082

# Optional: For local development without Docker
# LOCAL_DATABASE_URL=postgresql://user:password@localhost:5432/write_db
# LOCAL_READ_DATABASE_URL=postgresql://user:password@localhost:5433/read_db
# LOCAL_BROKER_URL=amqp://guest:guest@localhost:5672/